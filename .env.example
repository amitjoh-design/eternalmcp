# ============================================================
# Eternal MCP — Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# ----------------------------
# Supabase
# ----------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ----------------------------
# App
# ----------------------------
NEXT_PUBLIC_APP_URL=https://eternalmcp.com
NEXT_PUBLIC_APP_NAME=Eternal MCP

# ----------------------------
# GitHub OAuth (configured in Supabase)
# ----------------------------
# Set these in your Supabase project → Authentication → Providers → GitHub
# GITHUB_CLIENT_ID=your-github-client-id
# GITHUB_CLIENT_SECRET=your-github-client-secret

# ----------------------------
# Analytics (optional)
# ----------------------------
# NEXT_PUBLIC_POSTHOG_KEY=your-posthog-key
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
